{
  "name": "uxkm-guide",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --filter @uxkm/guide dev",
    "dev:all": "pnpm --parallel --filter @uxkm/guide --filter @uxkm/storybook dev",
    "build": "pnpm --filter @uxkm/guide build",
    "preview": "pnpm --filter @uxkm/guide preview",
    "storybook": "pnpm --filter @uxkm/storybook dev",
    "build-storybook": "pnpm --filter @uxkm/storybook build",
    "preview-storybook": "pnpm --filter @uxkm/storybook preview",
    "generate-stories": "node scripts/generate-stories.mjs",
    "generate-react-stories": "node scripts/generate-react-placeholder-stories.mjs",
    "deploy:main": "bash scripts/deploy-main.sh",
    "deploy:vue": "bash scripts/deploy-vue.sh"
  }
}
